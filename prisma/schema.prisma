generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id               String   @id @default(uuid()) @db.Uuid
  full_name        String
  email            String   @unique
  current_handicap  Float    @default(0)
  starting_handicap Float?           // Set on first score submission — used for improvement bonus
  is_active         Boolean  @default(true)
  created_at       DateTime @default(now())

  scores           Score[]
  handicap_history HandicapHistory[]
  season_bonuses   SeasonBonus[]
  club_yardages    ClubYardage[]

  @@map("members")
}

model Score {
  id                    String   @id @default(uuid()) @db.Uuid
  member_id             String?  @db.Uuid
  player_name           String
  holes                 Int
  gross_score           Int
  handicap_used         Float
  course_name           String
  course_difficulty     String   @default("average")
  difficulty_multiplier Float    @default(1.0)
  group_member_ids      String[] @default([])
  group_member_names    String   @default("")
  group_size            Int      @default(1)
  base_points           Float?
  group_bonus           Float    @default(0)
  additional_points     Float    @default(0)
  total_points          Float?
  play_date             DateTime
  notes                 String?
  created_at            DateTime @default(now())

  member           Member?          @relation(fields: [member_id], references: [id], onDelete: SetNull)
  handicap_history HandicapHistory[]

  @@map("scores")
}

model SeasonBonus {
  id           String   @id @default(uuid()) @db.Uuid
  member_id    String   @db.Uuid
  points       Float
  reason       String
  awarded_date DateTime @db.Date
  created_at   DateTime @default(now())

  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@map("season_bonuses")
}

model HandicapHistory {
  id          String   @id @default(uuid()) @db.Uuid
  member_id   String   @db.Uuid
  handicap    Float
  score_id    String?  @db.Uuid
  recorded_at DateTime @default(now())

  member Member  @relation(fields: [member_id], references: [id], onDelete: Cascade)
  score  Score?  @relation(fields: [score_id], references: [id], onDelete: SetNull)

  @@map("handicap_history")
}

model ClubYardage {
  id         String   @id @default(uuid()) @db.Uuid
  member_id  String   @db.Uuid
  club_name  String
  yards      Int
  created_at DateTime @default(now())

  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@unique([member_id, club_name])
  @@map("club_yardages")
}

// ── Dan's Birthday Event ───────────────────────────────────────────────────────

model BdayGroup {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  code         String    @unique
  location_lat Float?
  location_lon Float?
  location_at  DateTime?
  created_at   DateTime  @default(now())

  teams BdayTeam[]

  @@map("bday_groups")
}

model BdayTeam {
  id         String   @id @default(uuid()) @db.Uuid
  group_id   String   @db.Uuid
  name       String
  created_at DateTime @default(now())

  group              BdayGroup      @relation(fields: [group_id], references: [id], onDelete: Cascade)
  hole_scores        BdayHoleScore[]
  activities         BdayActivity[]
  mulligans_sent     BdayMulligan[] @relation("MulliganSender")
  mulligans_received BdayMulligan[] @relation("MulliganTarget")

  @@map("bday_teams")
}

model BdayHoleScore {
  id      String @id @default(uuid()) @db.Uuid
  team_id String @db.Uuid
  hole    Int
  strokes Int

  team BdayTeam @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@unique([team_id, hole])
  @@map("bday_hole_scores")
}

model BdayActivity {
  id        String   @id @default(uuid()) @db.Uuid
  team_id   String   @db.Uuid
  type      String   // "beer" | "hotdog"
  hole      Int?
  player    String?
  logged_at DateTime @default(now())

  team BdayTeam @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@map("bday_activities")
}

model BdayMulligan {
  id        String   @id @default(uuid()) @db.Uuid
  sender_id String   @db.Uuid
  target_id String   @db.Uuid
  hole      Int?
  fired_at  DateTime @default(now())

  sender BdayTeam @relation("MulliganSender", fields: [sender_id], references: [id], onDelete: Cascade)
  target BdayTeam @relation("MulliganTarget", fields: [target_id], references: [id], onDelete: Cascade)

  @@map("bday_mulligans")
}

model BdayMessage {
  id          String   @id @default(uuid()) @db.Uuid
  sender_name String
  text        String
  sent_at     DateTime @default(now())

  @@map("bday_messages")
}
